# =============================================
# Drone Food Delivery - Environment Variables
# =============================================

# Server
PORT=5000

# MongoDB Connection String
# Replace with your MongoDB URI (local or Atlas)
MONGO_URI=mongodb://localhost:27017/drone_delivery

# JWT Secret Key — change this to a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this

# JWT Expiry
JWT_EXPIRES_IN=7d
